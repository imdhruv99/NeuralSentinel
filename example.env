###############################
# KAFKA ENVIRONMENT VARIABLES #
###############################

KAFKA_IMAGE=apache/kafka:3.9.0
KAFKA_CLUSTER_ID=neuralsentinel-kafka-cluster

# KRaft quorum
KAFKA_CONTROLLER_QUORUM_VOTERS=1@kafka-controller:9093

# Shared settings (controllers + brokers)
KAFKA_LOG_DIRS=/var/lib/kafka/data

# Broker-only settings
KAFKA_LOG_RETENTION_HOURS=72
KAFKA_AUTO_CREATE_TOPICS_ENABLE=true
KAFKA_NUM_PARTITIONS=3
KAFKA_LOG_SEGMENT_BYTES=1073741824
KAFKA_LOG_CLEANER_ENABLE=true
KAFKA_DEFAULT_REPLICATION_FACTOR=2
KAFKA_MIN_INSYNC_REPLICAS=2
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=2
KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR=2
KAFKA_TRANSACTION_STATE_LOG_MIN_ISR=2
KAFKA_MESSAGE_MAX_BYTES=1048576

# Controller resource limits (metadata only — lighter than brokers)
KAFKA_CONTROLLER_MEM_LIMIT=512m
KAFKA_CONTROLLER_MEM_RESERVATION=320m
KAFKA_CONTROLLER_CPU_LIMIT=0.5

# Broker resource limits
KAFKA_BROKER_MEM_LIMIT=1g
KAFKA_BROKER_MEM_RESERVATION=640m
KAFKA_BROKER_CPU_LIMIT=0.75

# Kafka UI
KAFKA_UI_IMAGE=provectuslabs/kafka-ui:latest
KAFKA_UI_USER=admin
KAFKA_UI_PASSWORD=admin@123

####################################
# POSTGRESQL ENVIRONMENT VARIABLES #
####################################

# PostgreSQL
POSTGRES_IMAGE=postgres:16
POSTGRES_DB=projects
POSTGRES_USER=nueralsentinel
POSTGRES_PASSWORD=admin@123
POSTGRES_PASSWORD_ENCODED=admin%40123
POSTGRES_INITDB_ARGS=--encoding=UTF8

# Resource configs
POSTGRES_MEM_LIMIT=1g
POSTGRES_MEM_RESERVATION=640m
POSTGRES_CPU_LIMIT=0.75

# Least-privilege app user (created by conf/init.sql on first start)
# Application services connect as nsapp not as the superuser above.
NSAPP_PASSWORD=admin@123

# pgAdmin
PGADMIN_IMAGE=dpage/pgadmin4:9.5.0
PGADMIN_DEFAULT_EMAIL=nueralsentinel@dhruv.com
PGADMIN_DEFAULT_PASSWORD=admin@123
PGADMIN_HOST_PORT=58081

###############################
# REDIS ENVIRONMENT VARIABLES #
###############################

# Redis
REDIS_IMAGE=redis:7.2
REDIS_PASSWORD=admin@123
REDIS_MEM_LIMIT=512m
REDIS_MEM_RESERVATION=320m
REDIS_CPU_LIMIT=0.5

# Redis UI
REDIS_UI_IMAGE=rediscommander/redis-commander:latest
REDIS_UI_PORT=58082

################################
# MLFLOW ENVIRONMENT VARIABLES #
################################

MLFLOW_IMAGE=ghcr.io/mlflow/mlflow:v3.14.0
MLFLOW_HOST_PORT=58083
MLFLOW_DB=mlflow
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts
MLFLOW_MEM_LIMIT=2g
MLFLOW_MEM_RESERVATION=1g
MLFLOW_CPU_LIMIT=0.5

# Used by all application services to reach the tracking server
MLFLOW_TRACKING_URI=http://localhost:58083

#########################################
# APPLICATION SERVICES (host execution) #
#########################################
# Producers and the feature-windowing consumer run on the HOST (outside Docker),
# so they reach Kafka/Postgres/Redis through the externally mapped ports. These
# override the in-code defaults in services/*/config.py; leaving them unset falls
# back to those defaults.

# Kafka (external listener, see brokers above)
KAFKA_BOOTSTRAP_SERVERS=localhost:19091,localhost:19092
EVENTS_TOPIC=events.raw
SCORED_TOPIC=events.scored
ALERTS_TOPIC=alerts

# NAB producer
NAB_DATA_DIR=data/NAB/data
NAB_LABELS_FILE=data/NAB/labels/combined_labels.json
NAB_REPLAY_SPEED=0.0
# NAB_STREAM_FILTER=ec2_cpu_utilization_5f5533   # optional: replay one stream

# SMD producer
SMD_DATA_DIR=data/SMD/ServerMachineDataset
SMD_REPLAY_SPEED=0.0
SMD_USE_TEST_SPLIT=true
# SMD_MACHINE_FILTER=machine-1-1                 # optional: replay one machine

# Producer performance knobs
PRODUCER_BATCH_SIZE=16384
PRODUCER_LINGER_MS=5
PRODUCER_COMPRESSION=gzip

# Feature-windowing consumer
CONSUMER_GROUP=neural-sentinel-feature-windowing-consumer
# Event-time window: equal size+slide = tumbling (non-overlapping) windows.
WINDOW_SIZE_S=900.0
SLIDE_S=900.0
# Persist + commit once this many feature rows accumulate (backpressure knob).
CONSUMER_BATCH_MAX_ROWS=500
CONSUMER_POLL_TIMEOUT_MS=1000

# Postgres feature store - the consumer connects as the least-privilege nsapp
# user (NSAPP_PASSWORD above), not the superuser. POSTGRES_DB is shared above.
PG_HOST=localhost
PG_PORT=5432
PG_APP_USER=nsapp

# Redis online cache (latest feature row per entity).
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Isolation Forest training
CONTAMINATION=0.05
N_ESTIMATORS=300
MLFLOW_EXPERIMENT_NAME=neural-sentinel-isolation-forest
TRAIN_SEED=42
VALIDATION_RATIO=0.2
DATASET=NAB
IFOREST_STREAM_TYPE=UNIVARIATE
